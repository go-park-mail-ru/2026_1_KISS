{
  "openapi": "3.0.3",
  "info": {
    "title": "KISS Notebook API",
    "version": "1.0.0",
    "description": "REST API for collaborative Jupyter-like notebook platform"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataUserResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login and create session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "headers": {
              "Set-Cookie": {
                "schema": { "type": "string" },
                "description": "session_id cookie"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataUserResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Logout and destroy session",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "204": { "description": "Logged out" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": ["auth"],
        "summary": "Get current user",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataUserResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/notebooks": {
      "get": {
        "tags": ["notebooks"],
        "summary": "List user notebooks",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated notebook list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataNotebookListResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["notebooks"],
        "summary": "Create a notebook",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateNotebookRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Notebook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataNotebookResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/notebooks/{id}": {
      "get": {
        "tags": ["notebooks"],
        "summary": "Get notebook by ID",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" }
        ],
        "responses": {
          "200": {
            "description": "Notebook with blocks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataNotebookResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["notebooks"],
        "summary": "Update notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateNotebookRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notebook updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataNotebookResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["notebooks"],
        "summary": "Delete notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" }
        ],
        "responses": {
          "204": { "description": "Notebook deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/notebooks/{id}/blocks": {
      "post": {
        "tags": ["blocks"],
        "summary": "Add block to notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBlockRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Block created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataBlockResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/notebooks/{id}/blocks/{blockID}": {
      "put": {
        "tags": ["blocks"],
        "summary": "Update block",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" },
          { "$ref": "#/components/parameters/BlockID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBlockRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Block updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataBlockResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["blocks"],
        "summary": "Delete block",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" },
          { "$ref": "#/components/parameters/BlockID" }
        ],
        "responses": {
          "204": { "description": "Block deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": { "type": "string", "example": "ok" }
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Database unreachable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session_id"
      }
    },
    "parameters": {
      "NotebookID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer", "format": "int64" }
      },
      "BlockID": {
        "name": "blockID",
        "in": "path",
        "required": true,
        "schema": { "type": "integer", "format": "int64" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Not authenticated",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Forbidden": {
        "description": "Access denied",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Conflict": {
        "description": "Resource conflict",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "email", "password"],
        "properties": {
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "DataUserResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/UserResponse" }
        }
      },
      "CreateNotebookRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" }
        }
      },
      "UpdateNotebookRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "maxLength": 255 },
          "is_public": { "type": "boolean" }
        }
      },
      "NotebookResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "owner_id": { "type": "integer", "format": "int64" },
          "title": { "type": "string" },
          "is_public": { "type": "boolean" },
          "blocks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BlockResponse" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "DataNotebookResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/NotebookResponse" }
        }
      },
      "NotebookListResponse": {
        "type": "object",
        "properties": {
          "notebooks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NotebookResponse" }
          },
          "total": { "type": "integer" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" }
        }
      },
      "DataNotebookListResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/NotebookListResponse" }
        }
      },
      "CreateBlockRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "language": { "type": "string" },
          "content": { "type": "string" }
        }
      },
      "UpdateBlockRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "language": { "type": "string" },
          "content": { "type": "string" }
        }
      },
      "BlockResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "type": { "type": "string" },
          "language": { "type": "string" },
          "content": { "type": "string" },
          "position": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "DataBlockResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/BlockResponse" }
        }
      }
    }
  }
}
