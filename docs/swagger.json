{
  "openapi": "3.0.3",
  "info": {
    "title": "KISS — API совместных ноутбуков",
    "description": "REST API сервиса для совместной работы с ноутбуками. Аутентификация — сессионная через HttpOnly cookie.",
    "version": "1.0.0",
    "contact": {
      "name": "go-park-mail-ru/2026_1_KISS"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Локальный сервер разработки"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session_id",
        "description": "Идентификатор сессии в HttpOnly cookie. Выдаётся при POST /api/v1/auth/login."
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "email", "password"],
        "properties": {
          "username": {
            "type": "string",
            "example": "john_doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 1,
            "example": "secret123"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "secret123"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "john_doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-08T10:00:00Z"
          }
        }
      },
      "CreateNotebookRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Мои заметки по Python"
          }
        }
      },
      "CreateBlockRequest": {
        "type": "object",
        "required": ["type", "language", "content"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["code", "text", "markdown"],
            "example": "code"
          },
          "language": {
            "type": "string",
            "example": "python"
          },
          "content": {
            "type": "string",
            "example": "print('Привет, мир!')"
          }
        }
      },
      "BlockResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "type": {
            "type": "string",
            "example": "code"
          },
          "language": {
            "type": "string",
            "example": "python"
          },
          "content": {
            "type": "string",
            "example": "print('Привет, мир!')"
          },
          "position": {
            "type": "integer",
            "example": 0
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-08T10:00:00Z"
          }
        }
      },
      "NotebookResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "owner_id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Мои заметки по Python"
          },
          "is_public": {
            "type": "boolean",
            "example": false
          },
          "blocks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BlockResponse"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-08T10:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-08T10:05:00Z"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "description": "Конверт успешного ответа. Поле 'data' содержит полезную нагрузку.",
        "properties": {
          "data": {}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Конверт ответа с ошибкой.",
        "properties": {
          "error": {
            "type": "string",
            "example": "неверные учётные данные"
          }
        }
      }
    },
    "responses": {
      "400": {
        "description": "Неверный запрос — некорректный JSON или недопустимые значения полей.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "invalid request body"
            }
          }
        }
      },
      "401": {
        "description": "Не авторизован — отсутствует или истёк cookie сессии.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "invalid credentials"
            }
          }
        }
      },
      "403": {
        "description": "Доступ запрещён — пользователь аутентифицирован, но не имеет прав на ресурс.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "access denied"
            }
          }
        }
      },
      "404": {
        "description": "Не найдено — запрошенный ресурс не существует.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "not found"
            }
          }
        }
      },
      "409": {
        "description": "Конфликт — email или имя пользователя уже зарегистрированы.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "email or username already exists"
            }
          }
        }
      },
      "500": {
        "description": "Внутренняя ошибка сервера.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "internal server error"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Регистрация нового пользователя",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Пользователь успешно создан.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/UserResponse"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Вход в систему, получение cookie сессии",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Вход выполнен успешно. Устанавливается HttpOnly cookie `session_id`.",
            "headers": {
              "Set-Cookie": {
                "description": "HttpOnly cookie сессии: `session_id=<uuid>; Path=/; HttpOnly; SameSite=Lax`",
                "schema": {
                  "type": "string",
                  "example": "session_id=90619fff-b8e0-42b4-bee4-4e858d0745b0; Path=/; HttpOnly; SameSite=Lax"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/UserResponse"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Выход из системы, инвалидация сессии",
        "operationId": "logout",
        "description": "Очищает cookie `session_id`. Если cookie отсутствует, возвращает 200 без ошибки.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Выход выполнен успешно.",
            "headers": {
              "Set-Cookie": {
                "description": "Сбрасывает cookie сессии через MaxAge=-1.",
                "schema": {
                  "type": "string",
                  "example": "session_id=; Path=/; HttpOnly; Max-Age=0"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": ["auth"],
        "summary": "Получить текущего аутентифицированного пользователя",
        "operationId": "me",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Данные текущего пользователя.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/UserResponse"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    },
    "/api/v1/notebooks": {
      "get": {
        "tags": ["notebooks"],
        "summary": "Список ноутбуков текущего пользователя",
        "operationId": "listNotebooks",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Максимальное количество ноутбуков в ответе. 0 — без ограничения.",
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Количество ноутбуков для пропуска (пагинация).",
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Список ноутбуков.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/NotebookResponse"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      },
      "post": {
        "tags": ["notebooks"],
        "summary": "Создать новый ноутбук",
        "operationId": "createNotebook",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateNotebookRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ноутбук успешно создан.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/NotebookResponse"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    },
    "/api/v1/notebooks/{id}": {
      "get": {
        "tags": ["notebooks"],
        "summary": "Получить ноутбук по ID",
        "operationId": "getNotebook",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID ноутбука.",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ноутбук со всеми блоками.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/NotebookResponse"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      },
      "delete": {
        "tags": ["notebooks"],
        "summary": "Удалить ноутбук по ID",
        "operationId": "deleteNotebook",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID ноутбука.",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Ноутбук успешно удалён. Тело ответа отсутствует."
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    },
    "/api/v1/notebooks/{id}/blocks": {
      "post": {
        "tags": ["blocks"],
        "summary": "Добавить блок в ноутбук",
        "operationId": "addBlock",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID ноутбука.",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBlockRequest"
              },
              "example": {
                "type": "code",
                "language": "python",
                "content": "print('Привет, мир!')"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Блок создан и добавлен в ноутбук.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/BlockResponse"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "auth",
      "description": "Аутентификация и управление сессиями"
    },
    {
      "name": "notebooks",
      "description": "CRUD операции с ноутбуками"
    },
    {
      "name": "blocks",
      "description": "Блоки кода и текста внутри ноутбуков"
    }
  ]
}
