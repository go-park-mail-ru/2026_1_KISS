{
  "openapi": "3.0.3",
  "info": {
    "title": "KISS Notebook API",
    "version": "1.0.0",
    "description": "REST API for collaborative Jupyter-like notebook platform.\n\nAll successful responses are wrapped in `{\"data\": ...}`; errors in `{\"error\": \"message\"}`.\n\n**Auth flow in Swagger UI:**\n1. `POST /api/v1/auth/login` — response sets `session_id` and `csrf_token` cookies.\n2. Copy the `csrf_token` cookie value.\n3. Click **Authorize**: set `cookieAuth` = `session_id` value, set `csrfToken` = `csrf_token` value.\n4. All subsequent mutating requests will include `X-CSRF-Token` header automatically."
  },
  "servers": [
    {
      "url": "http://localhost:8083",
      "description": "Local development"
    }
  ],
  "tags": [
    { "name": "auth" },
    { "name": "profile" },
    { "name": "notebooks" },
    { "name": "blocks" },
    { "name": "permissions" },
    { "name": "runner" },
    { "name": "events" },
    { "name": "admin" },
    { "name": "health" }
  ],
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login and create session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful. Sets `session_id` and `csrf_token` cookies.",
            "headers": {
              "Set-Cookie": {
                "schema": { "type": "string" },
                "description": "session_id and csrf_token cookies"
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Logout and destroy session",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Logged out (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": ["auth"],
        "summary": "Get current user",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataUserResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/users/me": {
      "put": {
        "tags": ["profile"],
        "summary": "Update profile (username, status, description)",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateProfileRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/users/me/avatar": {
      "post": {
        "tags": ["profile"],
        "summary": "Upload avatar image",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["avatar"],
                "properties": {
                  "avatar": {
                    "type": "string",
                    "format": "binary",
                    "description": "Avatar image file"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Avatar uploaded; returns updated user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "413": { "$ref": "#/components/responses/PayloadTooLarge" }
        }
      }
    },
    "/api/v1/users/me/password": {
      "put": {
        "tags": ["profile"],
        "summary": "Change password",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangePasswordRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password changed (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/users/me/email": {
      "put": {
        "tags": ["profile"],
        "summary": "Change email",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangeEmailRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email changed; returns updated user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/notebooks": {
      "get": {
        "tags": ["notebooks"],
        "summary": "List user notebooks",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Title substring filter" }
        ],
        "responses": {
          "200": {
            "description": "Paginated notebook list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNotebookListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["notebooks"],
        "summary": "Create a notebook",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateNotebookRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Notebook created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNotebookResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/notebooks/shared": {
      "get": {
        "tags": ["notebooks"],
        "summary": "List notebooks shared with the current user",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of shared notebooks",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNotebookListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/notebooks/{id}": {
      "get": {
        "tags": ["notebooks"],
        "summary": "Get notebook by ID (with blocks)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/NotebookID" }],
        "responses": {
          "200": {
            "description": "Notebook with blocks",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNotebookResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["notebooks"],
        "summary": "Update notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/NotebookID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateNotebookRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notebook updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNotebookResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["notebooks"],
        "summary": "Delete notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/NotebookID" }],
        "responses": {
          "200": {
            "description": "Notebook deleted (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/notebooks/{id}/blocks": {
      "post": {
        "tags": ["blocks"],
        "summary": "Add block to notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/NotebookID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBlockRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Block created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataBlockResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/notebooks/{id}/blocks/{blockID}": {
      "put": {
        "tags": ["blocks"],
        "summary": "Update block",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" },
          { "$ref": "#/components/parameters/BlockID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateBlockRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Block updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataBlockResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["blocks"],
        "summary": "Delete block",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" },
          { "$ref": "#/components/parameters/BlockID" }
        ],
        "responses": {
          "200": {
            "description": "Block deleted (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/notebooks/{id}/permissions": {
      "get": {
        "tags": ["permissions"],
        "summary": "List permissions granted on a notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/NotebookID" }],
        "responses": {
          "200": {
            "description": "Permission list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataPermissionListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/notebooks/{id}/permissions/{userID}": {
      "put": {
        "tags": ["permissions"],
        "summary": "Grant a permission level to a user on a notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" },
          { "$ref": "#/components/parameters/UserID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GrantPermissionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Permission granted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataPermissionResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["permissions"],
        "summary": "Revoke a user's permission on a notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/NotebookID" },
          { "$ref": "#/components/parameters/UserID" }
        ],
        "responses": {
          "204": { "description": "Permission revoked" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/runner/{notebook_id}": {
      "post": {
        "tags": ["runner"],
        "summary": "Execute all blocks from a given position",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/RunnerNotebookID" },
          {
            "name": "block_position",
            "in": "query",
            "schema": { "type": "integer", "default": 0 },
            "description": "Starting block position (inclusive)"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of per-block execution results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataExecutionResultList" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/runner/{notebook_id}/block": {
      "post": {
        "tags": ["runner"],
        "summary": "Execute a single block",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/RunnerNotebookID" },
          {
            "name": "block_position",
            "in": "query",
            "schema": { "type": "integer", "default": 0 },
            "description": "Block position to execute"
          }
        ],
        "responses": {
          "200": {
            "description": "Execution result for the block",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataExecutionResult" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/runner/{notebook_id}/stop": {
      "post": {
        "tags": ["runner"],
        "summary": "Stop the runner session (kill container) for a notebook",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/RunnerNotebookID" }],
        "responses": {
          "200": {
            "description": "Session stopped (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/events/track": {
      "post": {
        "tags": ["events"],
        "summary": "Track a user analytics event",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TrackEventRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event recorded (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/admin/users": {
      "get": {
        "tags": ["admin"],
        "summary": "List all users (admin only)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of users",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataAdminUserListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/v1/admin/users/{id}/ban": {
      "post": {
        "tags": ["admin"],
        "summary": "Ban a user (admin only)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/UserPathID" }],
        "responses": {
          "200": {
            "description": "User banned (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/admin/users/{id}/unban": {
      "post": {
        "tags": ["admin"],
        "summary": "Unban a user (admin only)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/UserPathID" }],
        "responses": {
          "200": {
            "description": "User unbanned (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/admin/notebooks": {
      "get": {
        "tags": ["admin"],
        "summary": "List all notebooks (admin only)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of notebooks",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataAdminNotebookListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/v1/admin/notebooks/{id}": {
      "delete": {
        "tags": ["admin"],
        "summary": "Delete any notebook (admin only)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/NotebookID" }],
        "responses": {
          "200": {
            "description": "Notebook deleted (returns `{\"data\": null}`)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataNullResponse" }
              }
