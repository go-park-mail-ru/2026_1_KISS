# Сервер
SERVER_PORT=8080

# База данных (используется одно из двух: DATABASE_URL или отдельные поля)
DATABASE_URL=postgres://postgres:postgres@localhost:5437/colab?sslmode=disable

POSTGRES_HOST=localhost
POSTGRES_PORT=5437
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=colab
POSTGRES_SSLMODE=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_INTERNAL_PORT=6379

# Аутентификация
AUTH_SESSION_TTL=24h

# CORS (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:3000
