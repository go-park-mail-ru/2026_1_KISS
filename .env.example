# Сервер
SERVER_PORT=8080

# Аутентификация
AUTH_SESSION_TTL=24h
COOKIE_SECURE=false  # true в production (требует HTTPS)

# CORS (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:3000


# База данных (используется одно из двух: DATABASE_URL или отдельные поля)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/colab?sslmode=disable

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=colab
POSTGRES_SSLMODE=disable


# Redis
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_INTERNAL_PORT=6379


# Runner

RUNNER_NAME_PREFIX=runner-
RUNNER_AGENT_PORT=8080
RUNNER_MEMORY_LIMIT_BYTES=536870912  # 512MB
RUNNER_NANO_CPUS=1000000000          # 1 CPU
RUNNER_PIDS_LIMIT=64
RUNNER_TMPFS_SIZE=100m
NETWORK_NAME=bridge

# Images
RUNNER_IMAGE_PYTHON=kiss-python-runner

# Timeouts
RUNNER_STARTUP_TIMEOUT=20s
RUNNER_HEALTHCHECK_INTERVAL=300ms
RUNNER_IDLE_TIMEOUT=15m

# Uploads
UPLOAD_DIR=/app/uploads
UPLOAD_MAX_SIZE=2097152  # 2MB
