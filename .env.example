# Сервер
SERVER_PORT=8080

# База данных (используется одно из двух: DATABASE_URL или отдельные поля)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/colab?sslmode=disable

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=colab
POSTGRES_SSLMODE=disable

# Аутентификация
AUTH_SESSION_TTL=24h

# CORS (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:3000
