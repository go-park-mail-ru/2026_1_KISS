# ─── Сервер ───────────────────────────────────────────────────────────────────
SERVER_HOST=
SERVER_PORT=8080

# ─── Безопасность ─────────────────────────────────────────────────────────────
COOKIE_SECURE=false          # true в production (требует HTTPS)
DISABLE_KISS_CSRF=false      # true для ручного тестирования (Postman и т.п.), ТОЛЬКО ДЛЯ РАЗРАБОТКИ

# ─── CORS (через запятую) ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Аутентификация ───────────────────────────────────────────────────────────
AUTH_SESSION_TTL=24h

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=300
RATE_LIMIT_WINDOW=1m

# ─── База данных ──────────────────────────────────────────────────────────────
# Используется одно из двух: DATABASE_URL или отдельные поля
DATABASE_URL=postgres://postgres:postgres@localhost:5432/colab?sslmode=disable

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=colab
POSTGRES_SSLMODE=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_EXTERNAL_PORT=6380    # внешний порт docker-compose для Redis

# ─── gRPC адреса (для локального запуска без Docker) ──────────────────────────
AUTH_GRPC_ADDR=localhost:9001
NOTEBOOK_GRPC_ADDR=localhost:9002
RUNNER_GRPC_ADDR=localhost:9003

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
UPLOAD_MAX_SIZE=2097152      # 2MB в байтах

# ─── Runner ───────────────────────────────────────────────────────────────────
RUNNER_IMAGE_PYTHON=kiss-python-runner
RUNNER_NAME_PREFIX=runner-
RUNNER_AGENT_PORT=8080
RUNNER_MEMORY_LIMIT_BYTES=536870912   # 512MB
RUNNER_NANO_CPUS=1000000000           # 1 CPU
RUNNER_PIDS_LIMIT=64
RUNNER_TMPFS_SIZE=100m
NETWORK_NAME=bridge                   # kiss_app-network внутри Docker Compose

# Таймауты Runner
RUNNER_STARTUP_TIMEOUT=20s
RUNNER_HEALTHCHECK_INTERVAL=300ms
RUNNER_IDLE_TIMEOUT=15m
RUNNER_EXECUTION_TIMEOUT=120s

# ─── Метрики ──────────────────────────────────────────────────────────────────
METRICS_PORT=9090
